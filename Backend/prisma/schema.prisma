generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  email        String        @unique
  username     String?       @unique
  name         String?
  password     String
  medicines    Medicine[]
  Appointments Appointment[]
  CancerType   CancerType[]
  Reports      Report[]
}

model Hospital {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  address      String
  city         String
  contact      String
  email        String?
  bedsAvailable Int?         @default(0)
  facilities   String[]
  adminId      String?       @unique @db.ObjectId
  admin        Admin?        @relation(fields: [adminId], references: [adminId])
  doctors      Doctor[]
  appointments Appointment[]
  createdAt    DateTime      @default(now())
}

model Doctor {
  doctorId     String        @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  username     String?       @unique
  specialist   String
  experience   Int
  email        String        @unique
  password     String        @default("password123")
  rating       Float         @default(4.5)
  consultations Int          @default(0)
  hospitalId   String?       @db.ObjectId
  hospital     Hospital?     @relation(fields: [hospitalId], references: [id])
  appointments Appointment[]
  Reports      Report[]
  medicines    Medicine[]
  timeSlots    TimeSlot[]
}

model Appointment {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  date        String
  time        String
  patientName String
  doctor      Doctor    @relation(fields: [doctorId], references: [doctorId])
  user        User      @relation(fields: [userId], references: [id])
  userId      String    @db.ObjectId
  doctorId    String    @db.ObjectId
  hospitalId  String?   @db.ObjectId
  hospital    Hospital? @relation(fields: [hospitalId], references: [id])
  timeSlot    TimeSlot? @relation(fields: [timeSlotId], references: [id])
  timeSlotId  String?   @unique @db.ObjectId
  transcript        String?
  aiSummary         String?
  patientRoadmap    Json?     // Instructions, medications, follow-up
  status            String    @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED, REROUTED
  actualStartTime   DateTime?
  urgencyLevel      String    @default("NORMAL") // NORMAL, URGENT, EMERGENCY
}

model TimeSlot {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  date          String
  time          String
  status        String       @default("PENDING") // PENDING, AVAILABLE, BOOKED, FROZEN
  doctorId      String       @db.ObjectId
  doctor        Doctor       @relation(fields: [doctorId], references: [doctorId])
  appointment   Appointment?
}

model Admin {
  adminId  String @id @default(auto()) @map("_id") @db.ObjectId
  username String @unique
  password String
  role     String @default("admin")
  hospital Hospital?
}

model Medicine {
  medId       String   @id @default(auto()) @map("_id") @db.ObjectId
  medName     String
  description String
  dose        String
  frequency   String
  startDate   DateTime
  endDate     DateTime
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @db.ObjectId
  doctor      Doctor?  @relation(fields: [doctorId], references: [doctorId])
  doctorId    String?  @db.ObjectId
}

model CancerType {
  cancerId    String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  stage       Int
  description String
  symptoms    String
  treatments  String
  user        User   @relation(fields: [userId], references: [id])
  userId      String @db.ObjectId
}

model Report {
  reportId           String   @id @default(auto()) @map("_id") @db.ObjectId
  reportName         String
  reportUrl          String   // Cloud storage URL (Google Drive)
  parsedText         String?  // Full extracted text
  extractedMedicines Json?    // Structured medicine data
  status             String   @default("PROCESSED")
  date               DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id])
  userId             String   @db.ObjectId
  doctor             Doctor?  @relation(fields: [doctorId], references: [doctorId])
  doctorId           String?  @db.ObjectId
}
