# Database Connection
# Replace with your MongoDB connection string
DATABASE_URL="mongodb+srv://<username>:<password>@cluster.mongodb.net/cancure?retryWrites=true&w=majority"

# JWT Secret for Authentication
JWT_SECRET="cancure_secret_key_change_me"

# ML Service Configuration
# Defaults to localhost if running the Python backend locally
ML_SERVICE_URL="http://localhost:8000"

# Google Cloud Integration (OCR & Drive)
# The folder ID where reports will be saved
GOOGLE_DRIVE_FOLDER_ID="your_google_drive_folder_id"

# Port Configuration
PORT=3000
